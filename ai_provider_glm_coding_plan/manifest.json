{
  "id": "ai-provider-glm-coding-plan",
  "name": "GLM Coding Plan",
  "version": "0.2.1",
  "types": ["ai-provider"],
  "permissions": [],
  "risk_level": "low",
  "triggers": [],
  "entrypoints": {
    "ai_provider": "driver.build_driver"
  },
  "capabilities": {
    "ai_provider": {
      "adapter_code": "glm-coding-plan",
      "display_name": "GLM Coding Plan",
      "branding": {
        "logo_resource": "resources/logo.svg",
        "logo_resource_dark": "resources/logo.svg",
        "description_resource": "resources/description.json"
      },
      "field_schema": [
        {
          "key": "display_name",
          "label": "显示名称",
          "field_type": "text",
          "required": true,
          "placeholder": "GLM Coding Plan 主账号",
          "help_text": "这是当前家庭里看到的名称。",
          "default_value": null,
          "options": []
        },
        {
          "key": "provider_code",
          "label": "供应商编码",
          "field_type": "text",
          "required": true,
          "placeholder": "family-glm-coding-main",
          "help_text": "建议保持唯一，避免和别的供应商配置冲突。",
          "default_value": null,
          "options": []
        },
        {
          "key": "base_url",
          "label": "Base URL",
          "field_type": "select",
          "required": false,
          "placeholder": null,
          "help_text": "GLM Coding Plan 使用专用 Coding 端点，中国站和国际站不要混用。",
          "default_value": "https://open.bigmodel.cn/api/coding/paas/v4",
          "options": [
            {
              "label": "中国站",
              "value": "https://open.bigmodel.cn/api/coding/paas/v4"
            },
            {
              "label": "国际站",
              "value": "https://api.z.ai/api/coding/paas/v4"
            }
          ]
        },
        {
          "key": "secret_ref",
          "label": "API Key",
          "field_type": "secret",
          "required": true,
          "placeholder": "env://GLM_CODING_API_KEY",
          "help_text": "填环境变量引用或直接填专用 API Key。",
          "default_value": null,
          "options": []
        },
        {
          "key": "model_name",
          "label": "模型名称",
          "field_type": "text",
          "required": true,
          "placeholder": "glm-5",
          "help_text": "默认按当前官方 Coding 场景模型填写。快任务会自动关闭 thinking。",
          "default_value": "glm-5",
          "options": []
        },
        {
          "key": "privacy_level",
          "label": "隐私级别",
          "field_type": "select",
          "required": true,
          "placeholder": null,
          "help_text": "公网云通常就够了。",
          "default_value": "public_cloud",
          "options": [
            {
              "label": "公网云",
              "value": "public_cloud"
            },
            {
              "label": "私有云",
              "value": "private_cloud"
            }
          ]
        },
        {
          "key": "latency_budget_ms",
          "label": "延迟预算(ms)",
          "field_type": "number",
          "required": false,
          "placeholder": "15000",
          "help_text": "留空就走系统默认值。",
          "default_value": 15000,
          "options": []
        },
        {
          "key": "temperature",
          "label": "Temperature",
          "field_type": "number",
          "required": false,
          "placeholder": "0.2",
          "help_text": "需要稳定、快速时建议保持低温度。",
          "default_value": "0.2",
          "options": []
        },
        {
          "key": "max_tokens",
          "label": "Max Tokens",
          "field_type": "number",
          "required": false,
          "placeholder": "256",
          "help_text": "默认按速度优先，长回答再手动调大。",
          "default_value": 256,
          "options": []
        }
      ],
      "config_ui": {
        "field_order": [
          "display_name",
          "base_url",
          "secret_ref",
          "model_name",
          "privacy_level",
          "latency_budget_ms",
          "temperature",
          "max_tokens"
        ],
        "hidden_fields": ["provider_code"],
        "sections": [
          {
            "key": "connection",
            "title": "连接信息",
            "description": "只填 Coding Plan 专用地址和 API Key。",
            "fields": ["display_name", "base_url", "secret_ref"]
          },
          {
            "key": "runtime",
            "title": "运行参数",
            "description": "默认按加快回复速度收口，快任务会自动关 thinking、缩短输出和历史消息。",
            "fields": ["model_name", "privacy_level", "latency_budget_ms", "temperature", "max_tokens"]
          }
        ],
        "actions": []
      },
      "model_discovery": {
        "enabled": false,
        "action_key": null,
        "depends_on_fields": [],
        "target_field": null,
        "debounce_ms": 500,
        "empty_state_text": null,
        "discovery_hint_text": null,
        "discovering_text": null,
        "discovered_text_template": null
      },
      "supported_model_types": ["llm"],
      "llm_workflow": "openai_chat_completions",
      "runtime_capability": {
        "transport_type": "openai_compatible",
        "api_family": "openai_chat_completions",
        "default_privacy_level": "public_cloud",
        "default_supported_capabilities": ["text"]
      }
    }
  },
  "compatibility": {
    "min_app_version": "0.1.0",
    "provider_profile_schema_version": 1,
    "transport_type": "openai_compatible",
    "api_family": "openai_chat_completions",
    "description": "GLM Coding Plan 的官方插件接入，默认走专用 Coding API。"
  }
}
